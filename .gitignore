###############################################################################
# Rust GitIgnore Template
# Author: cuthanhcam
# Description: .gitignore for Rust + Cargo + VSCode
###############################################################################

# ---------------------------------------------------------------------------
# Rust / Cargo
# ---------------------------------------------------------------------------

# Compiled output
/target/

# Backup files generated by rustfmt
**/*.rs.bk

# Cargo lock
# Keep Cargo.lock for applications, ignore for libraries if needed
# (For learning repo → KEEP IT)
# Cargo.lock

# Draft / temporary writing folders anywhere
**/temp/
**/ref/

# ---------------------------------------------------------------------------
# IDE & Editor Files
# ---------------------------------------------------------------------------

# Visual Studio Code
.vscode/

# JetBrains (CLion / IntelliJ Rust plugin)
.idea/
*.iml

# ---------------------------------------------------------------------------
# OS Generated Files
# ---------------------------------------------------------------------------

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------

*.log
logs/
Logs/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------

.env
.env.*
*.key
*.pem

# ---------------------------------------------------------------------------
# Build Tools / Package Managers (Optional)
# ---------------------------------------------------------------------------

# Node.js (if you use frontend / tooling)
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if scripting / automation)
__pycache__/
*.pyc
*.pyo

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------

coverage/
*.profraw
*.profdata

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------

*.tmp
*.cache
*.bak

# ---------------------------------------------------------------------------
# LeetCode / Competitive Programming (Optional)
# ---------------------------------------------------------------------------

# Temporary input/output files
input.txt
output.txt

# ---------------------------------------------------------------------------
# Docker / DevOps (Optional)
# ---------------------------------------------------------------------------

.docker/
docker-compose.override.yml
.env.docker

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------
# - target/ is the most important ignore in Rust
# - Cargo.lock SHOULD be committed for apps (this repo is an app/learning repo)
# - Keep repo minimal and deterministic
###############################################################################

# Ignore compiled binaries and debug files
*.exe
*.pdb